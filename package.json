{
  "name": "bookprepper",
  "private": true,
  "version": "1.5.0",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build:packages": "pnpm --filter config build && pnpm --filter db build && pnpm --filter types build",
    "build": "pnpm build:packages && pnpm covers:cache && pnpm --filter api --filter web build",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter api test",
    "test:web": "pnpm --filter web test",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "prisma:migrate": "pnpm --filter db prisma migrate dev",
    "prisma:generate": "pnpm --filter db prisma generate",
    "prisma:seed": "pnpm --filter db seed",
    "covers:cache": "pnpm --filter api covers:cache"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "allowedScripts": [
      "@prisma/engines",
      "esbuild",
      "prisma"
    ],
    "overrides": {
      "esbuild": "^0.28.1",
      "lodash": "^4.17.23",
      "lodash-es": "^4.17.23",
      "fast-xml-parser": "^5.5.7",
      "defu": "^6.1.5",
      "handlebars": "^4.7.9",
      "bn.js": "^5.2.3",
      "minimatch": "^9.0.5",
      "flatted": "^3.3.4",
      "rollup": "^4.40.0",
      "fast-jwt": "^6.2.4",
      "hono": "^4.12.21",
      "@hono/node-server": "^1.19.13",
      "uuid": "^11.1.1"
    }
  }
}
